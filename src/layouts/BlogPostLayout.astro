---
import Layout from "./Layout.astro";
import BlogHeader from "../components/Blog/BlogHeader.astro";
import BlogMeta from "../components/Blog/BlogMeta.astro";
import type { BlogLocale } from "../utils/blog";
import "../styles/global.scss";
import "../styles/blog.scss";
import Contact from "../components/Contact/Contact.astro";
import { getTranslation } from "../i18n";
import "../styles/page.scss";

export interface Props {
	title: string;
	description?: string;
	locale: BlogLocale;
	homeLabel: string;
	blogLabel: string;
	themeToggleLabel: string;
	date: string;
	readTime: string;
	tag: string;
	slug: string;
}

const {
	title,
	description,
	locale,
	homeLabel,
	blogLabel,
	themeToggleLabel,
	date,
	readTime,
	tag,
	slug,
} = Astro.props;

const t = getTranslation(locale);
---

<Layout title={title} lang={locale} description={description}>
	<BlogHeader
		locale={locale}
		homeLabel={homeLabel}
		blogLabel={blogLabel}
		themeToggleLabel={themeToggleLabel}
		slug={slug}
	/>
	<main class="blog-main">
		<article class="blog-post">
			<h1 class="blog-post__title">{title}</h1>
			<BlogMeta date={date} readTime={readTime} tag={tag} />
			<div class="blog-post__content">
				<slot />
			</div>
		</article>

		<Contact title={t.sections.blogContactTitle} subtitle={t.sections.blogContactSubtitle} texts={t.sections} cvText={t.header.downloadCv} />
	</main>
</Layout>
