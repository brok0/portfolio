---
import type { BlogLocale, BlogPost } from "../../utils/blog";
import BlogMeta from "./BlogMeta.astro";

export interface Props {
	post: BlogPost;
	locale: BlogLocale;
	featured?: boolean;
	featuredLabel?: string;
}

const { post, locale, featured = false, featuredLabel = "Featured" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const href = `${baseUrl}${locale === "uk" ? "uk/" : ""}blog/${post.slug}/`;
---

<article class:list={["blog-card", { "blog-card--featured": featured }]}>
	<a href={href} class="blog-card__link">
		<div class="blog-card__content">
			{featured && <p class="blog-card__featured-label">{featuredLabel}</p>}
			<div class="blog-card__tag">{post.tag}</div>
			<h3 class="blog-card__title">{post.title}</h3>
			<p class="blog-card__description">{post.description}</p>
			<BlogMeta date={post.date} readTime={post.readTime} tag={post.tag} />
		</div>
	</a>
</article>
