---
import "../../styles/about.scss";

export interface Props {
	texts: {
		headingPrefix: string;
		headingHighlight: string;
		paragraphs: readonly string[];
		stats: ReadonlyArray<{ number: string; label: string }>;
		focusesTitle: string;
		focuses: ReadonlyArray<{ icon: string; title: string; subtitle: string }>;
		availabilityOpen: string;
		availabilityRemote: string;
		availabilityCountry: string;
	};
}

const { texts } = Astro.props;
const flagIconPath = `${import.meta.env.BASE_URL}Flag_of_Ukraine.svg`;
---

<section class="about" id="about">
	<h2 class="section__heading">
		{texts.headingPrefix}
		<span>{texts.headingHighlight}</span> 😸
	</h2>

	<div class="about__grid">
		<div class="about__bio-card">
			<p class="about__bio-text">
				{texts.paragraphs[0]}
				<br /><br />
				{texts.paragraphs[1]}
				<br /><br />
				{texts.paragraphs[2]}
			</p>
		</div>

		<div class="about__right">
			<!-- Stats -->
			<div class="about__stats">
				{
					texts.stats.map((stat) => (
						<div class="stat-card">
							<div class="stat-card__number">{stat.number}</div>
							<div class="stat-card__label">{stat.label}</div>
						</div>
					))
				}
			</div>

			<div class="about__focuses">
				<p class="focuses__title">{texts.focusesTitle}</p>
				<div class="focuses__list">
					{
						texts.focuses.map((item) => (
							<div class="focus-item">
								<div class="focus-item__icon">{item.icon}</div>
								<div class="focus-item__text">
									{item.title}
									<em>{item.subtitle}</em>
								</div>
							</div>
						))
					}
				</div>
			</div>

			<div class="about__availability">
				<div class="availability__text">
					<span class="availability__text__open">
						<div class="availability__dot"></div>
						<div>{texts.availabilityOpen}</div>
					</span>

					<span>· {texts.availabilityRemote}</span>

					<span class="availability__text__flag">
						· {texts.availabilityCountry}
						<img
							src={flagIconPath}
							alt={texts.availabilityCountry}
							class="flag-icon"
						/>
					</span>
				</div>
			</div>
		</div>
	</div>
</section>

<script src="./about.js"></script>
