---
import LinkButton from "../../components/LinkButton.astro";
import ThemeLangSwitcher from "../ThemeLangSwitcher.astro";
import "../../styles/header.scss";

export interface Props {
	labels: {
		about: string;
		projects: string;
		experience: string;
		certifications: string;
		contacts: string;
		downloadCv: string;
		switcherLabel: string;
		blog: string;
	};
	currentLocale: "en" | "uk";
}

const { labels, currentLocale } = Astro.props;
const cvPath = `${import.meta.env.BASE_URL}CV_Borys_Hlynskyi.pdf`;
const themeSwitcherLabel =
	currentLocale === "uk" ? "Перемкнути тему" : "Toggle theme";
const menuToggleLabel =
	currentLocale === "uk" ? "Перемкнути меню навігації" : "Toggle navigation menu";
---

<div class="header__wrap">
	<ThemeLangSwitcher
		class="header__switcher"
		currentLocale={currentLocale}
		enHref="/portfolio/"
		ukHref="/portfolio/uk/"
		themeSwitcherLabel={themeSwitcherLabel}
		ariaLabel={labels.switcherLabel}
	/>
	<div class="header__with-btn">
		<button
			type="button"
			class="header__menu-toggle"
			data-menu-toggle
			aria-label={menuToggleLabel}
			aria-expanded="false"
			aria-controls="mobile-navigation-menu"
		>
			<span class="header__menu-toggle-line"></span>
			<span class="header__menu-toggle-line"></span>
			<span class="header__menu-toggle-line"></span>
		</button>
		<nav class="header">
			<a href="#about">{labels.about}</a>
			<a href="#projects">{labels.projects}</a>
			<a href="#experience">{labels.experience}</a>
			<a href="#certifications">{labels.certifications}</a>
			<a href="#contacts">{labels.contacts}</a>
			<a href="#blog">{labels.blog}</a>
		</nav>
		<LinkButton
			download={{
				link: cvPath,
				file: "CV_Borys_Hlynskyi.pdf",
			}}
			text={labels.downloadCv}
		/>
		<div class="header__mobile-menu" id="mobile-navigation-menu" data-mobile-menu>
			<nav class="header__mobile-nav">
				<a href="#about">{labels.about}</a>
				<a href="#projects">{labels.projects}</a>
				<a href="#experience">{labels.experience}</a>
				<a href="#certifications">{labels.certifications}</a>
				<a href="#contacts">{labels.contacts}</a>
				<a href="#blog">{labels.blog}</a>
			</nav>
			<LinkButton
				download={{
					link: cvPath,
					file: "CV_Borys_Hlynskyi.pdf",
				}}
				text={labels.downloadCv}
			/>
		</div>
	</div>
</div>

<script>
	const menuToggle = document.querySelector("[data-menu-toggle]");
	const mobileMenu = document.querySelector("[data-mobile-menu]");
	const mobileMenuLinks = document.querySelectorAll("[data-mobile-menu] a");

	const setMobileMenuState = (isOpen) => {
		if (!menuToggle || !mobileMenu) return;
		menuToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
		mobileMenu.classList.toggle("is-open", isOpen);
		document.body.classList.toggle("menu-open", isOpen);
	};

	if (menuToggle && mobileMenu) {
		menuToggle.addEventListener("click", () => {
			const isOpen = menuToggle.getAttribute("aria-expanded") === "true";
			setMobileMenuState(!isOpen);
		});

		mobileMenuLinks.forEach((link) => {
			link.addEventListener("click", () => setMobileMenuState(false));
		});

		window.addEventListener("resize", () => {
			if (window.innerWidth >= 1024) {
				setMobileMenuState(false);
			}
		});
	}
</script>
