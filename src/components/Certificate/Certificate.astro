---
import LinkButton from "../LinkButton.astro";
import "../../styles/certificate.scss";
export interface Props {
	title: string;
	description: string;
	links: Array<{ url: string; title: string }>;
	author?: string;
	authorLabel?: string;
	classList?: string;
}

const { links, title, description, author, authorLabel = "Author", classList } = Astro.props;
---

<div class=`card__wrap ${classList} `>
	<div class="card">
		<div>
			<h4>{title}</h4>
			{
				author && (
					<p>
						<b>{authorLabel}:</b> {author}
					</p>
				)
			}
			<p>{description}</p>
		</div>
		<div class="card__links">
			{links.map((link) => <LinkButton link={link.url} text={link.title} />)}
		</div>
	</div>
</div>
