---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header/Header.astro";
import data from "../../data/uk.json";
import Project from "../../components/Project/Project.astro";
import LinkButton from "../../components/LinkButton.astro";
import Experience from "../../components/ExperienceBlock/Experience.astro";
import Skills from "../../components/SkillsBlock/Skills.astro";
import Certifications from "../../components/Certificate/Certifications.astro";
import "../../styles/page.scss";
import "../../styles/global.scss";
import AboutMe from "../../components/AboutMe/AboutMe.astro";
import { getTranslation } from "../../i18n";

const t = getTranslation("uk");
const cvPath = `${import.meta.env.BASE_URL}CV_Borys_Hlynskyi.pdf`;
---

<Layout title={t.meta.title} lang="uk">
	<Header labels={t.header} currentLocale="uk" />
	<main>
		<section>
			<h1 class="name">👋🏻 {t.hero.greeting}</h1>
			<h2 class="subhead">{t.hero.subtitle}</h2>
			<Skills skills={data.skills} />

			<AboutMe texts={t.about} />
		</section>

		<section id="projects">
			<h2 class="section__heading">
				{t.sections.projectsPrefix}
				<span>{t.sections.projectsHighlight}</span> 🧙🏻‍♂️
			</h2>

			{data.projects.map((e) => <Project data={e} texts={t.project} />)}
		</section>

		<section>
			<h2 class="section__heading">
				{t.experience.experienceHeaderFirst}
				<span>{t.experience.experienceHeaderSecond}</span>👨‍💻
			</h2>
		</section>

		<section class="experience__section" id="experience">
			<Experience texts={t.experience} />
		</section>

		<section id="certifications">
			<Certifications certificates={data.certificates} texts={t.certifications} />
		</section>

		<section class="contact__section" id="contacts">
			<div class="waves-block contact">
				<div class="contact__wrap">
					<div class="contact__wrap--bg"></div>
					<h2 class="contact__title">{t.sections.contactTitle}</h2>
					<p class="contact__subtitle">
						{t.sections.contactSubtitle}
						<b
							>bglinskii6@gmail.com
							<button
								class="copy-btn"
								type="button"
								data-copy-email="bglinskii6@gmail.com"
								aria-label="Copy email to clipboard"
								title="Copy email"
							>
								<svg
									xmlns="http://www.w3.org/2000/svg"
									xmlns:xlink="http://www.w3.org/1999/xlink"
									version="1.1"
									id="Layer_1"
									x="0px"
									width="20px"
									y="0px"
									viewBox="0 0 115.77 122.88"
									style="enable-background:new 0 0 115.77 122.88"
									xml:space="preserve"
									><style type="text/css">
										.st0 {
											fill-rule: evenodd;
											clip-rule: evenodd;
											fill: var(--text-primary);
										}
									</style><g
										><path
											class="st0"
											d="M89.62,13.96v7.73h12.19h0.01v0.02c3.85,0.01,7.34,1.57,9.86,4.1c2.5,2.51,4.06,5.98,4.07,9.82h0.02v0.02 v73.27v0.01h-0.02c-0.01,3.84-1.57,7.33-4.1,9.86c-2.51,2.5-5.98,4.06-9.82,4.07v0.02h-0.02h-61.7H40.1v-0.02 c-3.84-0.01-7.34-1.57-9.86-4.1c-2.5-2.51-4.06-5.98-4.07-9.82h-0.02v-0.02V92.51H13.96h-0.01v-0.02c-3.84-0.01-7.34-1.57-9.86-4.1 c-2.5-2.51-4.06-5.98-4.07-9.82H0v-0.02V13.96v-0.01h0.02c0.01-3.85,1.58-7.34,4.1-9.86c2.51-2.5,5.98-4.06,9.82-4.07V0h0.02h61.7 h0.01v0.02c3.85,0.01,7.34,1.57,9.86,4.1c2.5,2.51,4.06,5.98,4.07,9.82h0.02V13.96L89.62,13.96z M79.04,21.69v-7.73v-0.02h0.02 c0-0.91-0.39-1.75-1.01-2.37c-0.61-0.61-1.46-1-2.37-1v0.02h-0.01h-61.7h-0.02v-0.02c-0.91,0-1.75,0.39-2.37,1.01 c-0.61,0.61-1,1.46-1,2.37h0.02v0.01v64.59v0.02h-0.02c0,0.91,0.39,1.75,1.01,2.37c0.61,0.61,1.46,1,2.37,1v-0.02h0.01h12.19V35.65 v-0.01h0.02c0.01-3.85,1.58-7.34,4.1-9.86c2.51-2.5,5.98-4.06,9.82-4.07v-0.02h0.02H79.04L79.04,21.69z M105.18,108.92V35.65v-0.02 h0.02c0-0.91-0.39-1.75-1.01-2.37c-0.61-0.61-1.46-1-2.37-1v0.02h-0.01h-61.7h-0.02v-0.02c-0.91,0-1.75,0.39-2.37,1.01 c-0.61,0.61-1,1.46-1,2.37h0.02v0.01v73.27v0.02h-0.02c0,0.91,0.39,1.75,1.01,2.37c0.61,0.61,1.46,1,2.37,1v-0.02h0.01h61.7h0.02 v0.02c0.91,0,1.75-0.39,2.37-1.01c0.61-0.61,1-1.46,1-2.37h-0.02V108.92L105.18,108.92z"
										></path></g
									></svg
								></button
							><span class="copy-feedback" aria-live="polite"></span></b
						>
						{t.sections.contactOr}{" "}
						<b>{t.sections.linkedinName}</b>
					</p>
					<div class="contact__buttons">
						<LinkButton
							link="mailto:bglinskii6@gmail.com"
							text={t.sections.sendEmail}
						/>
						<LinkButton
							link="https://www.linkedin.com/in/borys-hlynskyi-16785b15b/"
							text={t.sections.linkedinProfile}
						/>
						<div class="contact__buttons--mobile">
							<LinkButton
								download={{
									link: cvPath,
									file: "CV_Borys_Hlynskyi.pdf",
								}}
								text={t.header.downloadCv}
							/>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script src="../index.js"></script>
