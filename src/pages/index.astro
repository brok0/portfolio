---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header/Header.astro";
import data from "../data/en.json";
import Project from "../components/Project/Project.astro";
import LinkButton from "../components/LinkButton.astro";
import Experience from "../components/ExperienceBlock/Experience.astro";
import Certifications from "../components/Certificate/Certifications.astro";
import "../styles/page.scss";
import "../styles/global.scss";
import "../styles/blog.scss";
import AboutMe from "../components/AboutMe/AboutMe.astro";
import BlogCard from "../components/Blog/BlogCard.astro";
import { getTranslation } from "../i18n";
import { getBlogPostsByLocale } from "../utils/blog";
import Hero from "../components/Hero/Hero.astro";
import Contact from "../components/Contact/Contact.astro";

const t = getTranslation("en");
const cvPath = `${import.meta.env.BASE_URL}CV_Borys_Hlynskyi.pdf`;
const posts = await getBlogPostsByLocale("en");
const featuredPost = posts.find((post) => post.featured) ?? posts[0];
const restPosts = posts
	.filter((post) => post.slug !== featuredPost?.slug)
	.slice(0, 2);
const allPostsHref = `${import.meta.env.BASE_URL}blog/`;
---

<Layout title={t.meta.title} lang="en" description={t.meta.description}>
	<Header labels={t.header} currentLocale="en" />
	<main>
		<section >
			<Hero t={t.hero} data={data} />
		</section>

		<section><AboutMe texts={t.about} /></section>

		<section id="projects">
			<h2 class="section__heading">
				{t.sections.projectsPrefix}
				<span class="highlight">{t.sections.projectsHighlight}</span> 🧙🏻‍♂️
			</h2>

			{data.projects.map((e) => <Project data={e} texts={t.project} />)}
		</section>
		
		<section class="experience__section" id="experience">
			<Experience texts={t.experience} />
		</section>

		<section id="certifications">
			<Certifications certificates={data.certificates} texts={t.certifications} />
		</section>

		<section class="home-blog" id="blog">
			<div class="home-blog__intro">
				<div>
					<h2 class="section__heading">
						{t.blog.heading}
						<span class="highlight">{t.blog.headingHighlight}</span>
					</h2>
					<p class="home-blog__subheading">{t.blog.subheading}</p>
				</div>
				<a class="home-blog__all-link" href={allPostsHref}>{t.blog.allPosts} →</a>
			</div>

			<div class="blog-grid">
				{
					featuredPost && (
						<BlogCard
							post={featuredPost}
							locale="en"
							featured={true}
							featuredLabel={t.blog.featured}
						/>
					)
				}
				{restPosts.map((post) => <BlogCard post={post} locale="en" />)}
			</div>
		</section>

		<Contact title={t.sections.contactTitle} subtitle={t.sections.contactSubtitle} texts={t.sections} cvText={t.header.downloadCv} />
	</main>
</Layout>

<script src="./index.js"></script>
